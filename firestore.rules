rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    //  FUNCIÓN HELPER: Verificar si es Super Admin
    function isSuperAdmin() {
      return exists(/databases/$(database)/documents/SuperAdmin/$(request.auth.uid));
    }
    
    // Reportes: acceso para autenticados
    match /Reportes/{ReporteId} {
      allow read, write: if request.auth != null;
    }
    match /Reportes {
      allow list: if request.auth != null;
    }
    
    // Conductores: acceso para autenticados
    match /Conductores/{conductorId} {
      allow read, write: if request.auth != null;
    }
    match /Conductores {
      allow list: if request.auth != null;
    }
    
    // Unidades CON subcolecciones RutaDiaria y EventoDiario
    match /Unidades/{unidadId} {
      allow read, write: if request.auth != null;


      
      match /RutaDiaria/{rutaId} {
        allow read, write: if request.auth != null;
        
        match /EventoDiario/{eventoId} {
          allow read, write: if request.auth != null;
        }
      }
    }
    match /Unidades {
      allow list: if request.auth != null;
    }
    // UbicacionesGlobal: para sincronización frontend-forwarder
    match /UbicacionesGlobal/{ubicacionId} {
      allow read, write: if request.auth != null;
    }
    match /UbicacionesGlobal {
      allow list: if request.auth != null;
    }
    
    //  USUARIOS: Super Admins pueden ver todo, usuarios normales solo lo suyo
    match /Usuarios/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      
      // SUBCOLECCIÓN POIS
      match /POIS/{poiId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      }
      
      // SUBCOLECCIÓN GruposConductores
      match /GruposConductores/{grupoId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      }
      
      //  NUEVA: SUBCOLECCIÓN GruposGeozonas
      match /GruposGeozonas/{grupoId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      }
      
      // SUBCOLECCIÓN Geozonas
      match /Geozonas/{geozonaId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      }
      
      // SUBCOLECCIÓN Eventos
      match /Eventos/{eventoId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      }
      
      // SUBCOLECCIÓN HistorialReportes
      match /HistorialReportes/{reporteId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      }
    }
    
    //  LISTAR USUARIOS: Super Admins pueden listar, usuarios normales pueden listar (para buscar)
    match /Usuarios {
      allow list: if request.auth != null;
    }
    
    // Super Admins (solo lectura para verificación)
    match /SuperAdmin/{adminId} {
      allow read: if true;
      allow write: if false; // Solo manual desde consola
    }
    
  }
}